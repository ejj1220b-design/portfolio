<script>
// ── Cursor
const cur = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{ mx=e.clientX; my=e.clientY; cur.style.transform=`translate(${mx-4}px,${my-4}px)`; });
(function loop(){ rx+=(mx-rx)*0.1; ry+=(my-ry)*0.1; ring.style.transform=`translate(${rx-15}px,${ry-15}px)`; requestAnimationFrame(loop); })();
document.querySelectorAll('a,button,.case-card').forEach(el=>{ el.addEventListener('mouseenter',()=>{ ring.style.width='44px'; ring.style.height='44px'; ring.style.opacity='0.7'; }); el.addEventListener('mouseleave',()=>{ ring.style.width='30px'; ring.style.height='30px'; ring.style.opacity='0.4'; }); });

// ── Nav scroll
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>40));

// ── Reveal on scroll
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);} }),{threshold:0.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ── iMessage animation (scroll-triggered)
let imsgPlayed = false;

const imsgObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting && !imsgPlayed) {
      imsgPlayed = true;
      playImsg();
    }
  });
}, { threshold: 0.3 });

const imsgSection = document.getElementById('hero-imsg');
if (imsgSection) imsgObs.observe(imsgSection);

function showTyping() {
  const row = document.getElementById('typing');
  const bubble = document.getElementById('typingBubble');
  row.classList.remove('hidden');
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      bubble.classList.add('visible');
    });
  });
}

function hideTyping() {
  const row = document.getElementById('typing');
  const bubble = document.getElementById('typingBubble');
  bubble.classList.remove('visible');
  setTimeout(() => row.classList.add('hidden'), 300);
}

function showBubble(id) {
  const row = document.getElementById(id);
  if (!row) return;
  row.style.display = 'flex';
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const b = row.querySelector('.bubble');
      if (b) b.classList.add('visible');
    });
  });
}

function playImsg() {
  // 각 메시지: [타이핑 시작, 버블 등장, 다음 타이핑까지 읽기 대기]
  // b1: 짧음 — 타이핑 0.9초, 읽기 1.6초
  setTimeout(() => showTyping(), 400);
  setTimeout(() => { hideTyping(); showBubble('b1'); }, 1300);

  // b2: 두 줄 — 타이핑 1초, 읽기 2초
  setTimeout(() => showTyping(), 2900);
  setTimeout(() => { hideTyping(); showBubble('b2'); }, 3900);

  // b3: 긴 문장 — 타이핑 1초, 읽기 2.5초
  setTimeout(() => showTyping(), 6000);
  setTimeout(() => { hideTyping(); showBubble('b3'); }, 7100);

  // b4: 중간 — 타이핑 0.9초, 읽기 2초
  setTimeout(() => showTyping(), 9700);
  setTimeout(() => { hideTyping(); showBubble('b4'); }, 10600);

  // b5: 짧고 강함 — 타이핑 0.9초
  setTimeout(() => showTyping(), 12700);
  setTimeout(() => {
    hideTyping();
    showBubble('b5');
    setTimeout(() => {
      const hint = document.getElementById('imsgHint');
      if (hint) hint.classList.add('show');
    }, 1800);
  }, 13600);
}

// ── Modal
function openModal(id){ document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden'; }
function closeModal(id){ document.getElementById(id).classList.remove('open'); document.body.style.overflow=''; }
function closeOnBg(e,el){ if(e.target===el){el.classList.remove('open'); document.body.style.overflow='';} }
document.addEventListener('keydown',e=>{ if(e.key==='Escape') document.querySelectorAll('.modal-overlay.open').forEach(m=>{m.classList.remove('open');document.body.style.overflow='';}); });
</script>
